language = C
package = dev.koml.engine.native
headers = llama.h
headerFilter = llama.h ggml*.h
# Metal disabled on macOS too — the b5460 ggml-common embed bug turns out to
# affect macOS hosts (not just iOS, as we initially thought). Fall back to
# Accelerate-only CPU, same as iOS. Revisit when bumping llama.cpp.
linkerOpts = -lc++ -framework Foundation -framework Accelerate
staticLibraries = libkoml-llama.a
