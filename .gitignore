# ─── Gradle / Build ──────────────────────────────────────────
.gradle/
build/
out/
local.properties

# ─── Kotlin Multiplatform caches ─────────────────────────────
.kotlin/
.kotlin-native/

# ─── IDEs ────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.fleet/

# ─── OS junk ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Android native build artifacts ──────────────────────────
.cxx/
.externalNativeBuild/

# ─── Android signing (never commit) ──────────────────────────
*.keystore
*.jks
keystore.properties
release.properties

# ─── JVM crash / heap dumps ──────────────────────────────────
*.hprof
hs_err_pid*
replay_pid*
*.log

# ─── Xcode (KomlSample.xcodeproj is generated by XcodeGen) ───
samples-ios/**/*.xcodeproj
samples-ios/**/*.xcworkspace
samples-ios/**/xcuserdata/
samples-ios/**/DerivedData/
*.xccheckout
*.xcscmblueprint
*.xcuserstate

# ─── Swift Package Manager (defensive; not used today) ───────
.swiftpm/
Package.resolved

# ─── CocoaPods (defensive; not used today) ───────────────────
Pods/
*.podspec.lock

# ─── Local secrets / environment ─────────────────────────────
.env
.env.local
.envrc

# ─── Editor swap files ───────────────────────────────────────
*.swp
*.swo
*~

# ─── Models — large binaries, never commit anywhere ──────────
*.gguf
*.bin
*.safetensors
*.onnx
*.mlpackage/
